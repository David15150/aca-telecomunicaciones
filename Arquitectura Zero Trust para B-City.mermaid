graph TB
    subgraph "Principio: NUNCA CONFÍES, SIEMPRE VERIFICA"
        direction TB
        
        subgraph "Acceso desde cualquier ubicación"
            Z1["Ciudadano<br/>(Internet)"]
            Z2["Funcionario<br/>(Oficina/Remoto)"]
            Z3["Administrador<br/>(On-premise)"]
            Z4["Sensor IoT<br/>(Red municipal)"]
        end
        
        subgraph "Capa 1: Verificación de Identidad"
            V1["Autenticación Multifactor<br/>(MFA - Funcionarios)"]
            V2["Certificados Digitales<br/>(Sensores IoT)"]
            V3["OAuth 2.0 / OIDC<br/>(Portal Ciudadano)"]
            V4["Federación con AD<br/>(Administradores)"]
        end
        
        subgraph "Capa 2: Verificación de Dispositivo"
            D1["Endpoint Compliance<br/>(Antivirus, parches)"]
            D2["Huella Digital<br/>(Browser fingerprinting)"]
            D3["Modelo Confianza<br/>(Comportamiento anómalo)"]
        end
        
        subgraph "Capa 3: Autorización Microsegmentada"
            M1["Policy: Acceso a BD<br/>(Solo desde pods autorizados)"]
            M2["Policy: Acceso a S3<br/>(Solo servicios específicos)"]
            M3["Policy: Acceso a API<br/>(Rate limiting, WAF)"]
            M4["Policy: Acceso VoIP<br/>(Solo SBC autorizado)"]
        end
        
        subgraph "Capa 4: Monitoreo Continuo"
            C1["Análisis de Comportamiento<br/>(UEBA)"]
            C2["Detección de Anomalías<br/>(Machine Learning)"]
            C3["Registro de Eventos<br/>(CloudTrail + Splunk)"]
        end
        
        Z1 & Z2 & Z3 & Z4 --> V1 & V2 & V3 & V4
        V1 & V2 & V3 & V4 --> D1 & D2 & D3
        D1 & D2 & D3 --> M1 & M2 & M3 & M4
        M1 & M2 & M3 & M4 --> C1 & C2 & C3
    end
    
    style Z1 fill:#FFDAB9,stroke:#CD7F4B,stroke-width:2px
    style Z2 fill:#FFDAB9,stroke:#CD7F4B,stroke-width:2px
    style Z3 fill:#FFB6C1,stroke:#B22222,stroke-width:2px
    style Z4 fill:#F4A460,stroke:#8B4513,stroke-width:2px
    
    style V1 fill:#87CEEB,stroke:#1E4A76,stroke-width:2px
    style V2 fill:#87CEEB,stroke:#1E4A76,stroke-width:2px
    style V3 fill:#87CEEB,stroke:#1E4A76,stroke-width:2px
    style V4 fill:#87CEEB,stroke:#1E4A76,stroke-width:2px
    
    style D1 fill:#98FB98,stroke:#228B22,stroke-width:2px
    style D2 fill:#98FB98,stroke:#228B22,stroke-width:2px
    style D3 fill:#98FB98,stroke:#228B22,stroke-width:2px
    
    style M1 fill:#FFB6C1,stroke:#B22222,stroke-width:2px
    style M2 fill:#FFB6C1,stroke:#B22222,stroke-width:2px
    style M3 fill:#FFB6C1,stroke:#B22222,stroke-width:2px
    style M4 fill:#FFB6C1,stroke:#B22222,stroke-width:2px
    
    style C1 fill:#FFE4B5,stroke:#CD853F,stroke-width:2px
    style C2 fill:#FFE4B5,stroke:#CD853F,stroke-width:2px
    style C3 fill:#FFE4B5,stroke:#CD853F,stroke-width:2px